# EmuFlow Environment Configuration
# Kopieer dit bestand naar .env en vul de waarden in

# ── API ──────────────────────────────────────────────────────────────────────
APP_ENV=development
APP_SECRET_KEY=change-this-to-a-secure-random-string-in-production
APP_PORT=8000
APP_HOST=0.0.0.0

# ── Database ─────────────────────────────────────────────────────────────────
DATABASE_URL=postgresql+asyncpg://emuflow:password@localhost:5432/emuflow_db

# ── Redis (voor caching) ──────────────────────────────────────────────────────
REDIS_URL=redis://localhost:6379/0

# ── Supabase (alternatief voor eigen Postgres/Redis) ──────────────────────────
# SUPABASE_URL=https://your-project.supabase.co
# SUPABASE_ANON_KEY=your-anon-key
# SUPABASE_SERVICE_KEY=your-service-key

# ── GitHub API (voor update checks — hogere rate limit met token) ─────────────
GITHUB_TOKEN=ghp_your_token_here

# ── AI Support ────────────────────────────────────────────────────────────────
# Provider: 'openai' of 'ollama' (lokaal)
SUPPORT_AI_PROVIDER=openai
OPENAI_API_KEY=sk-your-openai-key-here
OPENAI_MODEL=gpt-4o-mini

# Ollama (als je lokaal draait, geen kosten)
# OLLAMA_BASE_URL=http://localhost:11434
# OLLAMA_MODEL=llama3.2

# ── Update Scheduler ─────────────────────────────────────────────────────────
UPDATE_CHECK_INTERVAL_HOURS=24
UPDATE_CACHE_FILE=/tmp/emuflow_update_cache.json

# ── Android Agent ────────────────────────────────────────────────────────────
# Draait op het Android device zelf, communiceert met de backend
AGENT_BACKEND_URL=https://your-emuflow-backend.railway.app
AGENT_DEVICE_TOKEN=your-device-specific-token
