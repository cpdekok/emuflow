<?xml version="1.0" encoding="utf-8"?>
<!--
    Data Extraction Rules — Android 12+ (API 31+)
    Bepaalt wat er bij device-transfer (cloud backup / ADB backup) wordt meegenomen.

    Privacy-besluit: SharedPreferences met device-ID worden NIET geback-upt.
    Zo krijgt elk nieuw device een eigen, unieke ID.
    De vault-data staat op externe opslag en valt buiten deze rules.
-->
<data-extraction-rules>
    <cloud-backup>
        <exclude domain="sharedpref" path="emuflow_agent_prefs.xml" />
        <exclude domain="sharedpref" path="emuflow_settings.xml" />
    </cloud-backup>
    <device-transfer>
        <exclude domain="sharedpref" path="emuflow_agent_prefs.xml" />
    </device-transfer>
</data-extraction-rules>
